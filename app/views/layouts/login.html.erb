<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "ログイン - Exit Examination Rails" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= favicon_link_tag "coffee_c_brand_favicon.svg", type: "image/svg+xml" %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[#efefef] flex items-center justify-center p-4">
    <div class="w-full max-w-xl mx-auto">
      <%= yield %>
    </div>
  </body>
</html>
