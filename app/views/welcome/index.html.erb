<!DOCTYPE html>
<html lang="ja" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MyCoffeeNote - コーヒー好み分析メモアプリ</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= favicon_link_tag 'coffee_c_brand_favicon.svg', type: 'image/svg+xml' %>
</head>
<body class="h-full bg-gradient-to-br from-amber-50 to-orange-50">
  <!-- Hero Section -->
  <section class="min-h-screen flex flex-col justify-center px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Logo/Icon -->
      <div class="mb-8">
        <%= image_tag "coffee_beans_image.png", class: "mx-auto w-24 h-24 sm:w-32 sm:h-32", alt: "MyCoffeeNote" %>
      </div>
      
      <!-- Main Title -->
      <h1 class="text-4xl sm:text-6xl font-bold text-gray-900 mb-6">
        <span class="text-amber-600">MyCoffeeNote</span>
      </h1>
      
      <p class="text-xl sm:text-2xl text-gray-700 mb-8 leading-relaxed">
        コーヒー豆の好みを記録・可視化・分析する<br class="hidden sm:block">
        コーヒー愛好家のための専用Webアプリ
      </p>
      
      <!-- Main CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <%= link_to "無料で始める", new_user_registration_path, 
            class: "bg-amber-600 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-700 transition-colors shadow-lg" %>
        <%= link_to "ログイン", new_user_session_path, 
            class: "border-2 border-amber-600 text-amber-600 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-50 transition-colors" %>
      </div>
      
      <!-- Scroll indicator -->
      <div class="animate-bounce">
        <svg class="mx-auto w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-gray-900 mb-12">
        3つの主要機能
      </h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="text-center p-6 rounded-lg bg-amber-50 border border-amber-200">
          <div class="w-16 h-16 bg-amber-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">豆の記録管理</h3>
          <p class="text-gray-600">
            品種・焙煎度・精製方法・農園情報・味の感想・購入店を詳細に記録
          </p>
        </div>
        
        <!-- Feature 2 -->
        <div class="text-center p-6 rounded-lg bg-green-50 border border-green-200">
          <div class="w-16 h-16 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">産地可視化</h3>
          <p class="text-gray-600">
            産地を地図上に表示して、自分の好みの傾向を視覚的に把握
          </p>
        </div>
        
        <!-- Feature 3 -->
        <div class="text-center p-6 rounded-lg bg-blue-50 border border-blue-200">
          <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">AI好み分析</h3>
          <p class="text-gray-600">
            ChatGPT連携による好み分析とおすすめ豆の提案機能
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Use Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-gray-900 mb-12">
        使い方は簡単4ステップ
      </h2>
      
      <div class="space-y-8">
        <!-- Step 1 -->
        <div class="flex flex-col md:flex-row items-center gap-6">
          <div class="flex-shrink-0 w-16 h-16 bg-amber-600 rounded-full flex items-center justify-center">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <div class="text-center md:text-left">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">アカウント登録</h3>
            <p class="text-gray-600">無料でアカウントを作成してログイン</p>
          </div>
        </div>
        
        <!-- Step 2 -->
        <div class="flex flex-col md:flex-row items-center gap-6">
          <div class="flex-shrink-0 w-16 h-16 bg-amber-600 rounded-full flex items-center justify-center">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <div class="text-center md:text-left">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">コーヒー豆を登録</h3>
            <p class="text-gray-600">購入した豆の品種・焙煎度・農園などの詳細情報を記録</p>
          </div>
        </div>
        
        <!-- Step 3 -->
        <div class="flex flex-col md:flex-row items-center gap-6">
          <div class="flex-shrink-0 w-16 h-16 bg-amber-600 rounded-full flex items-center justify-center">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <div class="text-center md:text-left">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">味や感想を記録</h3>
            <p class="text-gray-600">飲んだ感想や評価をテイスティングノートとして保存</p>
          </div>
        </div>
        
        <!-- Step 4 -->
        <div class="flex flex-col md:flex-row items-center gap-6">
          <div class="flex-shrink-0 w-16 h-16 bg-amber-600 rounded-full flex items-center justify-center">
            <span class="text-2xl font-bold text-white">4</span>
          </div>
          <div class="text-center md:text-left">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">好みを分析・発見</h3>
            <p class="text-gray-600">AIが好み傾向を分析し、新しいおすすめ豆を提案</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Target Users Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-8">
        こんな方におすすめ
      </h2>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 rounded-lg bg-yellow-50 border border-yellow-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">豆を買って自宅で楽しむ方</h3>
          <p class="text-sm text-gray-600">スペシャルティコーヒーを購入して自宅で淹れて楽しんでいる</p>
        </div>
        
        <div class="p-6 rounded-lg bg-yellow-50 border border-yellow-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">好みを深掘りしたい方</h3>
          <p class="text-sm text-gray-600">自分の好みの豆・焙煎・精製・農園・お店を詳しく知りたい</p>
        </div>
        
        <div class="p-6 rounded-lg bg-yellow-50 border border-yellow-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">信頼できるお店を探したい方</h3>
          <p class="text-sm text-gray-600">接客の良いお店や信頼できる焙煎士を見つけたい</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-amber-600">
    <div class="max-w-3xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        今すぐ始めて、コーヒーライフをもっと楽しく
      </h2>
      
      <p class="text-xl text-amber-100 mb-8">
        無料でアカウント作成。あなただけのコーヒー記録を始めましょう。
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to "無料でアカウント作成", new_user_registration_path, 
            class: "bg-white text-amber-600 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-gray-50 transition-colors shadow-lg" %>
        <%= link_to "ログイン", new_user_session_path, 
            class: "border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-700 transition-colors" %>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="text-white text-lg font-semibold mb-4 md:mb-0">
          MyCoffeeNote
        </div>
        
        <div class="flex space-x-6">
          <%= link_to "利用規約", "policies/terms-of-service", 
              class: "text-gray-300 hover:text-white transition-colors" %>
          <%= link_to "プライバシーポリシー", "policies/privacy-policy", 
              class: "text-gray-300 hover:text-white transition-colors" %>
        </div>
      </div>
      
      <div class="mt-6 pt-6 border-t border-gray-700 text-center text-gray-400 text-sm">
        © 2025 MyCoffeeNote. All rights reserved.
      </div>
    </div>
  </footer>

  <%= javascript_importmap_tags %>
</body>
</html>