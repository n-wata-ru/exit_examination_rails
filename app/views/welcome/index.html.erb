<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MyCoffeeNote - コーヒー好み分析メモアプリ</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-gray-50 text-gray-900">
  <!-- Hero Section -->
  <header class="bg-gradient-to-r from-amber-600 to-orange-600 text-white py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-5xl font-bold mb-4">MyCoffeeNote</h1>
      <p class="text-xl mb-8">コーヒー豆の好みを記録・可視化・分析する、コーヒー愛好家のための専用Webアプリ</p>
      <div class="space-x-4">
        <%= link_to "無料で始める", new_user_registration_path, class: "bg-white text-amber-600 px-8 py-3 rounded-lg font-semibold text-lg hover:bg-gray-100 transition-colors inline-block" %>
        <%= link_to "ログイン", new_user_session_path, class: "border-2 border-white text-white px-8 py-3 rounded-lg font-semibold text-lg hover:bg-white hover:text-amber-600 transition-colors inline-block" %>
      </div>
    </div>
  </header>

  <!-- Features Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">主な機能</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="bg-amber-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">豆の記録管理</h3>
          <p class="text-gray-600">購入したコーヒー豆の品種・焙煎度・精製方法・農園情報・味の感想を詳細に記録できます</p>
        </div>
        <div class="text-center p-6">
          <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">産地可視化</h3>
          <p class="text-gray-600">コーヒー豆の産地を地図上に表示して、自分の好みの傾向を視覚的に理解できます</p>
        </div>
        <div class="text-center p-6">
          <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">AI好み分析</h3>
          <p class="text-gray-600">ChatGPT連携による好み分析とおすすめ豆の提案で、あなたの理想のコーヒーを発見</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Use Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">使い方</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-2xl font-bold text-amber-600 mb-2">STEP 1</div>
          <h3 class="font-semibold mb-2">アカウント作成</h3>
          <p class="text-gray-600 text-sm">無料でアカウントを作成して、コーヒー記録を始めましょう</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-2xl font-bold text-amber-600 mb-2">STEP 2</div>
          <h3 class="font-semibold mb-2">豆情報を登録</h3>
          <p class="text-gray-600 text-sm">購入した豆の品種、焙煎度、産地、購入店などを記録</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-2xl font-bold text-amber-600 mb-2">STEP 3</div>
          <h3 class="font-semibold mb-2">味の記録</h3>
          <p class="text-gray-600 text-sm">飲んだ感想や味の評価をテイスティングノートとして保存</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-2xl font-bold text-amber-600 mb-2">STEP 4</div>
          <h3 class="font-semibold mb-2">好み分析</h3>
          <p class="text-gray-600 text-sm">AIが記録を分析して、あなたにぴったりの豆を提案</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Target Users Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">こんな方におすすめ</h2>
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div class="p-6">
          <div class="bg-amber-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">☕</span>
          </div>
          <h3 class="font-semibold mb-2">豆を買って自宅で楽しむ人</h3>
          <p class="text-gray-600 text-sm">スペシャルティコーヒーを購入して、自宅で本格的なコーヒーを楽しまれる方</p>
        </div>
        <div class="p-6">
          <div class="bg-green-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🔍</span>
          </div>
          <h3 class="font-semibold mb-2">好みを深掘りしたい人</h3>
          <p class="text-gray-600 text-sm">自分の好みの豆・焙煎・精製方法・農園・お店を深く理解したい方</p>
        </div>
        <div class="p-6">
          <div class="bg-blue-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl">🏪</span>
          </div>
          <h3 class="font-semibold mb-2">信頼できるお店を探したい人</h3>
          <p class="text-gray-600 text-sm">接客の良いお店や信頼できる焙煎士を見つけて記録したい方</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-r from-amber-600 to-orange-600 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">今すぐ始めてみませんか？</h2>
      <p class="text-xl mb-8">あなたのコーヒー体験をより豊かなものにしましょう</p>
      <div class="space-x-4">
        <%= link_to "無料で始める", new_user_registration_path, class: "bg-white text-amber-600 px-8 py-3 rounded-lg font-semibold text-lg hover:bg-gray-100 transition-colors inline-block" %>
        <%= link_to "ログイン", new_user_session_path, class: "border-2 border-white text-white px-8 py-3 rounded-lg font-semibold text-lg hover:bg-white hover:text-amber-600 transition-colors inline-block" %>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-800 text-white py-8">
    <div class="container mx-auto px-4 text-center">
      <p class="mb-4">&copy; 2024 MyCoffeeNote. All rights reserved.</p>
      <div class="space-x-6">
        <%= link_to "利用規約", policies_terms_of_service_path, class: "text-gray-300 hover:text-white" %>
        <%= link_to "プライバシーポリシー", policies_privacy_policy_path, class: "text-gray-300 hover:text-white" %>
      </div>
    </div>
  </footer>
</body>
</html>